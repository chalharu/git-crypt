{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "automerge": true,
  "automergeStrategy": "auto",
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "pin",
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "automergeStrategy": "auto",
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    }
  ]
}
