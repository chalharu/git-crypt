{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "automergeStrategy": "auto",
  "minimumReleaseAge": "3 days",
  "pinDigests": false,
  "rangeStrategy": "pin",
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "automergeStrategy": "auto",
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "/^(?!actions\\/|github\\/).+/"
      ],
      "pinDigests": true
    }
  ]
}
